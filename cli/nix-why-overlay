#!/usr/bin/env bash
# nix-why-overlay - which overlay sets this attribute? (v0.5)
#
# Two modes:
#
#   listing      nix-why-overlay <flake-target>
#                  Lists every overlay applied to the target's nixpkgs
#                  and the top-level attributes each contributes.
#
#   attribution  nix-why-overlay <flake-target> <attr-path>
#                  For a specific attribute (e.g. pkgs.firefox), folds
#                  the overlays one at a time against a baseline
#                  nixpkgs and reports which overlay introduced or
#                  modified the attribute.

set -euo pipefail

print_usage() {
  cat << 'EOF'
nix-why-overlay - explain how an attribute came to be on pkgs

Usage:
  nix-why-overlay <flake-target>                  (listing mode)
  nix-why-overlay <flake-target> <attr-path>      (attribution mode)

Flake targets:
  .#nixosConfigurations.<host>
  .#darwinConfigurations.<host>
  .#homeConfigurations."<user@host>"
  .#legacyPackages.<system>

Attribute path:
  Dotted path INTO pkgs - e.g. `firefox`, `firefox.override`,
  `python311Packages.requests`.

Flags:
  --json              Emit the AST as JSON
  --no-color          Force-disable ANSI escapes (also respects NO_COLOR)
  --limit N           (listing) cap the per-overlay attribute list at N
                      (default 20)
  --show-trace        Pass through to nix eval
  -h, --help          Show this help

Exit codes:
  0   overlays listed OR attribution completed
  1   attribution: attribute never appeared in any overlay step
  3   flake target not found, no overlays discoverable, or baseline
      nixpkgs source could not be located
  4   evaluation error
  64  usage error
EOF
}

format="tree"
no_color=0
show_trace=0
attr_limit=20
positional=()

if [[ -n "${NO_COLOR:-}" ]] || ! [[ -t 1 ]]; then
  no_color=1
fi

while (($# > 0)); do
  case "$1" in
    --json)
      format="json"
      shift
      ;;
    --no-color)
      no_color=1
      shift
      ;;
    --limit)
      attr_limit="$2"
      shift 2
      ;;
    --limit=*)
      attr_limit="${1#*=}"
      shift
      ;;
    --show-trace)
      show_trace=1
      shift
      ;;
    -h | --help)
      print_usage
      exit 0
      ;;
    -*)
      echo "nix-why-overlay: unknown flag '$1'" >&2
      print_usage >&2
      exit 64
      ;;
    *)
      positional+=("$1")
      shift
      ;;
  esac
done

if (("${#positional[@]}" < 1 || "${#positional[@]}" > 2)); then
  echo "nix-why-overlay: expected <flake-target> [<attr-path>] (got ${#positional[@]} positional args)" >&2
  print_usage >&2
  exit 64
fi

flake_target="${positional[0]}"
attr_path="${positional[1]:-}"

if [[ "$flake_target" == *"#"* ]]; then
  flake_ref="${flake_target%%#*}"
  attr_expr="${flake_target#*#}"
else
  flake_ref="$flake_target"
  attr_expr=""
fi
[[ -z "$flake_ref" ]] && flake_ref="."

if ((no_color)); then
  C_RESET=""
  C_BOLD=""
  C_DIM=""
  C_CYAN=""
  C_YELLOW=""
  C_GREEN=""
  C_MAGENTA=""
else
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_CYAN=$'\033[36m'
  C_YELLOW=$'\033[33m'
  C_GREEN=$'\033[32m'
  C_MAGENTA=$'\033[35m'
fi

# ---------------------------------------------------------------------------
# Build the Nix expression
# ---------------------------------------------------------------------------
# The expression branches on whether attr_path is given:
#   - empty:        listing mode (each overlay's contributed attrs)
#   - non-empty:    attribution mode (cumulative fold + signature diff)
#
# Both modes share the discovery logic: locate overlays + applied pkgs +
# the original nixpkgs source for a clean baseline.
nix_expr=$(
  cat << NIXEXPR
let
  lib = (import <nixpkgs> { }).lib;
  flake = builtins.getFlake ("${flake_ref}");

  flakeAttr = "${attr_expr}";
  parts = if flakeAttr == "" then [ ] else lib.splitString "." flakeAttr;
  target =
    if parts == [ ] then
      throw "nix-why-overlay: no attribute path given after '#'"
    else
      lib.attrByPath parts (throw "nix-why-overlay: attribute path '\${flakeAttr}' not found in flake") flake;

  attrPath = "${attr_path}";
  pathParts = if attrPath == "" then [ ] else lib.splitString "." attrPath;

  discovery =
    let
      tries = [
        (
          if (target ? config && target.config ? nixpkgs && target.config.nixpkgs ? overlays && target.config ? _module && target.config._module ? args && target.config._module.args ? pkgs)
          then { pkgs = target.config._module.args.pkgs; overlays = target.config.nixpkgs.overlays; nixpkgsConfig = target.config.nixpkgs.config or { }; }
          else null
        )
        (
          if (target ? _module && target._module ? args && target._module.args ? pkgs && target._module.args.pkgs ? overlays)
          then { inherit (target._module.args) pkgs; overlays = target._module.args.pkgs.overlays; nixpkgsConfig = target._module.args.pkgs.config or { }; }
          else null
        )
        (
          if (target ? overlays && target ? pkgs && builtins.isList target.overlays)
          then { inherit (target) pkgs overlays; nixpkgsConfig = target.pkgs.config or { }; }
          else null
        )
        (
          if (target ? lib && target ? stdenv && target ? overlays && builtins.isList target.overlays)
          then { pkgs = target; inherit (target) overlays; nixpkgsConfig = target.config or { }; }
          else null
        )
      ];
      hit = lib.findFirst (x: x != null) null tries;
    in
    hit;
in
if discovery == null then
  {
    error = "could not locate overlays on the target. Tried NixOS/HM/darwin config.nixpkgs, _module.args.pkgs, target.overlays, and target-is-pkgs shapes. Point me at .#nixosConfigurations.<host> or .#legacyPackages.<system>.";
  }
else
  let
    pkgs = discovery.pkgs;
    overlays = discovery.overlays;

    # Try to recover the underlying nixpkgs source. \`pkgs.path\` is the
    # standard way; falls back to null when the pkgs instance was built
    # in a way that did not retain it.
    nixpkgsSrc = pkgs.path or null;
    canBuildBaseline = nixpkgsSrc != null;

    system = pkgs.stdenv.hostPlatform.system or builtins.currentSystem;

    # Baseline pkgs: the same nixpkgs source the target uses, but with
    # no user overlays applied. Used only in attribution mode.
    baselinePkgs =
      if canBuildBaseline
      then import nixpkgsSrc { inherit system; config = discovery.nixpkgsConfig; overlays = [ ]; }
      else null;

    # Cumulative fold: [ baseline, after-o0, after-o1, ... ]
    cumulatives =
      if canBuildBaseline
      then lib.foldl (acc: ov: acc ++ [ ((lib.last acc).extend ov) ]) [ baselinePkgs ] overlays
      else [ ];

    # Compute a comparable signature for the attribute at one pkgs step.
    sigOf =
      pkgsInst:
      let
        tried = builtins.tryEval (lib.attrByPath pathParts null pkgsInst);
      in
      if !tried.success then
        { kind = "eval-error"; }
      else if tried.value == null then
        { kind = "missing"; }
      else
        let
          v = tried.value;
          drvTried = builtins.tryEval (v.drvPath or null);
          namesTried = builtins.tryEval (if builtins.isAttrs v then builtins.attrNames v else [ ]);
          strTried = builtins.tryEval (
            if builtins.isFunction v then "<function>"
            else builtins.toString v
          );
        in
        if builtins.isAttrs v && drvTried.success && drvTried.value != null then
          { kind = "derivation"; drvPath = drvTried.value; }
        else if builtins.isAttrs v then
          { kind = "attrset"; attrNames = if namesTried.success then namesTried.value else [ ]; }
        else if builtins.isFunction v then
          { kind = "function"; }
        else if builtins.isList v then
          { kind = "list"; length = builtins.length v; }
        else
          { kind = builtins.typeOf v; value = if strTried.success then strTried.value else "(unprintable)"; };

    signatures = map sigOf cumulatives;

    # One diff per overlay: comparing signatures[i] to signatures[i+1].
    diffOf =
      i:
      let
        prev = builtins.elemAt signatures i;
        curr = builtins.elemAt signatures (i + 1);
        same = prev == curr;
        prevMissing = prev.kind == "missing";
        currMissing = curr.kind == "missing";
        kind =
          if same then "unchanged"
          else if prevMissing && !currMissing then "introduced"
          else if !prevMissing && currMissing then "removed"
          else "modified";
      in
      {
        overlayIndex = i;
        kind = kind;
        prevKind = prev.kind;
        currKind = curr.kind;
        prevSummary = builtins.toJSON prev;
        currSummary = builtins.toJSON curr;
      };

    diffs =
      if pathParts == [ ] then [ ]
      else lib.genList diffOf (builtins.length overlays);

    changeDiffs = lib.filter (d: d.kind != "unchanged") diffs;

    summary =
      if pathParts == [ ] then null
      else
        let
          firstAppearance =
            let
              baseline = builtins.head signatures;
              firstChange = lib.findFirst (d: d.kind == "introduced") null diffs;
            in
            if baseline.kind != "missing" then "baseline"
            else if firstChange != null then "overlay ${toString firstChange.overlayIndex}"
            else "never";
          lastModification =
            let
              last = lib.findFirst (d: true) null (lib.reverseList changeDiffs);
            in
            if last == null then "none" else "overlay ${toString last.overlayIndex} (${last.kind})";
        in
        {
          inherit firstAppearance lastModification;
          changeCount = builtins.length changeDiffs;
          finalKind = (lib.last signatures).kind;
        };

    # Listing mode (no attrPath given): keep the v0.4 MVP behaviour.
    listingOverlays =
      let
        describe =
          idx: overlay:
          let
            applied = builtins.tryEval (overlay pkgs pkgs);
            names =
              if applied.success && builtins.isAttrs applied.value
              then builtins.attrNames applied.value
              else [ ];
          in
          {
            index = idx;
            appliedOk = applied.success;
            attributeCount = builtins.length names;
            attributes = names;
          };
      in
      lib.imap0 describe overlays;
  in
  if pathParts == [ ] then
    {
      mode = "listing";
      error = null;
      overlayCount = builtins.length overlays;
      overlays = listingOverlays;
    }
  else if !canBuildBaseline then
    {
      mode = "attribution";
      error = "could not locate baseline nixpkgs source (pkgs.path is unset on this target). Attribution requires a baseline to fold overlays against.";
    }
  else
    {
      mode = "attribution";
      error = null;
      path = attrPath;
      overlayCount = builtins.length overlays;
      signatures = signatures;
      diffs = diffs;
      inherit summary;
    }
NIXEXPR
)

nix_eval_args=(--impure --json --expr "${nix_expr}")
((show_trace)) && nix_eval_args+=(--show-trace)

stderr_file="$(mktemp)"
trap 'rm -f "${stderr_file}"' EXIT
nix_rc=0
ast_json="$(nix eval "${nix_eval_args[@]}" 2> "${stderr_file}")" || nix_rc=$?
nix_stderr="$(cat "${stderr_file}")"

if ((nix_rc != 0)); then
  case "$nix_stderr" in
    *"nix-why-overlay: attribute path"* | \
      *"nix-why-overlay: no attribute path given"*)
      echo "$nix_stderr" >&2
      exit 3
      ;;
    *)
      echo "$nix_stderr" >&2
      exit 4
      ;;
  esac
fi

err="$(printf '%s' "$ast_json" | jq -r '.error // empty')"
if [[ -n "$err" ]]; then
  echo "nix-why-overlay: $err" >&2
  exit 3
fi

if [[ "$format" == "json" ]]; then
  printf '%s\n' "$ast_json"
  # Attribution: exit 1 if the attribute never appeared anywhere.
  if [[ "$(printf '%s' "$ast_json" | jq -r '.mode')" == "attribution" ]]; then
    final_kind="$(printf '%s' "$ast_json" | jq -r '.summary.finalKind // "missing"')"
    [[ "$final_kind" == "missing" ]] && exit 1
  fi
  exit 0
fi

mode="$(printf '%s' "$ast_json" | jq -r '.mode')"

if [[ "$mode" == "listing" ]]; then
  overlay_count="$(printf '%s' "$ast_json" | jq -r '.overlayCount')"
  printf '%btarget:%b %s\n' "$C_BOLD" "$C_RESET" "$flake_target"
  printf '%boverlays:%b %d\n\n' "$C_BOLD" "$C_RESET" "$overlay_count"

  if ((overlay_count == 0)); then
    printf '  %b(no overlays applied)%b\n' "$C_DIM" "$C_RESET"
    exit 0
  fi

  while IFS= read -r overlay; do
    idx=$(jq -r '.index' <<< "$overlay")
    ok=$(jq -r '.appliedOk' <<< "$overlay")
    count=$(jq -r '.attributeCount' <<< "$overlay")
    printf '  %boverlay %d%b' "$C_CYAN" "$idx" "$C_RESET"
    if [[ "$ok" == "false" ]]; then
      printf ' %b(evaluation failed; cannot enumerate attributes)%b\n' "$C_YELLOW" "$C_RESET"
      continue
    fi
    printf '  %b%d attribute%s contributed%b\n' \
      "$C_DIM" "$count" "$(((count == 1) ? "" : "s"))" "$C_RESET"
    while IFS= read -r attr; do
      printf '    - %s\n' "$attr"
    done < <(jq -r --argjson lim "$attr_limit" '.attributes[0:$lim][]' <<< "$overlay")
    if ((count > attr_limit)); then
      printf '    %b...%d more (raise --limit to see)%b\n' "$C_DIM" "$((count - attr_limit))" "$C_RESET"
    fi
  done < <(jq -c '.overlays[]' <<< "$ast_json")
  exit 0
fi

# -------- attribution mode --------------------------------------------------

# Render a single signature object as a compact one-line summary.
format_sig() {
  local s="$1"
  local k
  k=$(jq -r '.kind' <<< "$s")
  case "$k" in
    derivation)
      printf 'derivation drvPath=%s' "$(jq -r '.drvPath' <<< "$s")"
      ;;
    attrset)
      printf 'attrset (%d keys)' "$(jq -r '.attrNames | length' <<< "$s")"
      ;;
    list)
      printf 'list (%d items)' "$(jq -r '.length' <<< "$s")"
      ;;
    function) printf 'function' ;;
    missing) printf '%b(not present)%b' "$C_DIM" "$C_RESET" ;;
    eval-error) printf '%b(eval error)%b' "$C_YELLOW" "$C_RESET" ;;
    *) printf '%s' "$(jq -r '"\(.kind)=\(.value // "?")"' <<< "$s")" ;;
  esac
}

path="$(printf '%s' "$ast_json" | jq -r '.path')"
overlay_count="$(printf '%s' "$ast_json" | jq -r '.overlayCount')"

printf '%battribute:%b %s\n' "$C_BOLD" "$C_RESET" "$path"
printf '%btarget:%b    %s\n' "$C_BOLD" "$C_RESET" "$flake_target"
printf '%boverlays:%b  %d\n\n' "$C_BOLD" "$C_RESET" "$overlay_count"

printf '%bHistory:%b\n' "$C_BOLD" "$C_RESET"
baseline_sig=$(jq -c '.signatures[0]' <<< "$ast_json")
printf '  %bbaseline%b                       %s\n' "$C_DIM" "$C_RESET" "$(format_sig "$baseline_sig")"

idx=0
while IFS= read -r diff; do
  kind=$(jq -r '.kind' <<< "$diff")
  curr_sig=$(jq -c ".signatures[$((idx + 1))]" <<< "$ast_json")
  case "$kind" in
    introduced)
      marker="+"
      color="$C_GREEN"
      ;;
    modified)
      marker="~"
      color="$C_MAGENTA"
      ;;
    removed)
      marker="-"
      color="$C_YELLOW"
      ;;
    *)
      marker=" "
      color="$C_DIM"
      ;;
  esac
  printf '  %s %boverlay %-2d %-12s%b  %s\n' "$marker" "$color" "$idx" "$kind" "$C_RESET" "$(format_sig "$curr_sig")"
  idx=$((idx + 1))
done < <(jq -c '.diffs[]' <<< "$ast_json")

echo
printf '%bSummary:%b\n' "$C_BOLD" "$C_RESET"
printf '  first appearance:   %s\n' "$(jq -r '.summary.firstAppearance' <<< "$ast_json")"
printf '  last modification:  %s\n' "$(jq -r '.summary.lastModification' <<< "$ast_json")"
printf '  total changes:      %s\n' "$(jq -r '.summary.changeCount' <<< "$ast_json")"
printf '  final state:        %s\n' "$(jq -r '.summary.finalKind' <<< "$ast_json")"

final_kind="$(printf '%s' "$ast_json" | jq -r '.summary.finalKind // "missing"')"
[[ "$final_kind" == "missing" ]] && exit 1
exit 0
