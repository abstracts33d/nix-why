#!/usr/bin/env bash
# nix-why-option - module-system option resolution debugger
#
# Given a flake target and an option path, prints the option's final
# value plus every contributing definition with file:line, priority
# annotation, and mkIf condition.
#
# Usage:
#   nix-why-option <flake-target> <option-path> [flags]
#   nix-why-option eval <expr> <option-path> [flags]
#
# See `nix-why-option --help` for full flag reference.

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration: where to find the nix-why library + driver expressions
# ---------------------------------------------------------------------------
# The packaged binary sets NIX_WHY_LIB and NIX_WHY_CLI_EXPR_DIR at wrap
# time. For local development from a clone, fallback to script-relative
# paths.
self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
: "${NIX_WHY_LIB:=${self_dir}/../lib}"
: "${NIX_WHY_CLI_EXPR_DIR:=${self_dir}/expr}"
: "${NIX_WHY_CLI_SH:=${self_dir}/_lib.sh}"

if [[ ! -f "${NIX_WHY_LIB}/default.nix" ]]; then
  echo "nix-why-option: NIX_WHY_LIB does not point at a valid library directory: ${NIX_WHY_LIB}" >&2
  exit 64
fi

if [[ ! -f "${NIX_WHY_CLI_EXPR_DIR}/resolve.nix" ]]; then
  echo "nix-why-option: NIX_WHY_CLI_EXPR_DIR does not point at a valid driver-expression directory: ${NIX_WHY_CLI_EXPR_DIR}" >&2
  exit 64
fi

if [[ ! -f "${NIX_WHY_CLI_SH}" ]]; then
  echo "nix-why-option: NIX_WHY_CLI_SH does not point at the shared lib: ${NIX_WHY_CLI_SH}" >&2
  exit 64
fi
# shellcheck source=./_lib.sh
source "${NIX_WHY_CLI_SH}"

# ---------------------------------------------------------------------------
# Argv parsing
# ---------------------------------------------------------------------------
print_usage() {
  cat << 'EOF'
nix-why-option - module-system option resolution debugger

Usage:
  nix-why-option <flake-target> <option-path> [flags]
  nix-why-option eval <expr> <option-path> [flags]
  nix-why-option what-sets <flake-target> <option-path> [flags]
  nix-why-option why-not <flake-target> <option-path> [flags]
  nix-why-option search <flake-target> <pattern> [flags]

Examples:
  nix-why-option .#nixosConfigurations.krach services.openssh.enable
  nix-why-option .#krach services.openssh.enable     (shorthand schema autodetect)
  nix-why-option .#homeConfigurations."s33d@krach" programs.git.userEmail

Flags:
  --json              Emit the full introspection AST as JSON
  --brief, -b         One-line output: <path> = <value>  (...)
  --no-color          Force-disable ANSI escapes (also respects NO_COLOR)
  --max-value N       Truncate value rendering past N characters (default 200)
  --show-trace        Pass through to nix eval for debugging the tool itself
  --verbose           Show informational notices (e.g. module-walk
                      opt-in tips). Silent by default.
  --adapter <name>    Force a specific adapter
                      (nixos | home-manager | nix-darwin | flake-parts | raw)
  --limit N           (search only) cap on the number of matches
                      shown; 0 disables truncation (default 50)
  -h, --help          Show this help

Exit codes:
  0   option resolved
  1   option declared but not defined
  2   option does not exist
  3   flake target not found or wrong schema
  4   evaluation error (passed through from nix eval)
  64  usage error
EOF
}

format="tree"
adapter_name=""
max_value=200
no_color=0
show_trace=0
search_limit=50
verbose=0
positional=()

# Color autodetect: disabled if NO_COLOR is set or stdout is not a TTY.
if [[ -n "${NO_COLOR:-}" ]] || ! [[ -t 1 ]]; then
  no_color=1
fi

while (($# > 0)); do
  case "$1" in
    --json) format="json"; shift ;;
    --brief | -b) format="brief"; shift ;;
    --no-color) no_color=1; shift ;;
    --max-value)
      max_value="$2"
      shift 2
      ;;
    --max-value=*)
      max_value="${1#*=}"
      shift
      ;;
    --show-trace) show_trace=1; shift ;;
    --verbose) verbose=1; shift ;;
    --limit)
      search_limit="$2"
      shift 2
      ;;
    --limit=*)
      search_limit="${1#*=}"
      shift
      ;;
    --adapter)
      adapter_name="$2"
      shift 2
      ;;
    --adapter=*)
      adapter_name="${1#*=}"
      shift
      ;;
    -h | --help)
      print_usage
      exit 0
      ;;
    --)
      shift
      positional+=("$@")
      break
      ;;
    -*)
      echo "nix-why-option: unknown flag '$1'" >&2
      print_usage >&2
      exit 64
      ;;
    *)
      positional+=("$1")
      shift
      ;;
  esac
done

# Subcommand dispatch.
subcommand=""
if (("${#positional[@]}" >= 1)); then
  case "${positional[0]}" in
    eval | what-sets | search | why-not)
      subcommand="${positional[0]}"
      positional=("${positional[@]:1}")
      ;;
  esac
fi

if (("${#positional[@]}" != 2)); then
  case "$subcommand" in
    eval)
      echo "nix-why-option eval: expected <expr> <option-path> (got ${#positional[@]} positional args)" >&2
      ;;
    what-sets)
      echo "nix-why-option what-sets: expected <flake-target> <option-path> (got ${#positional[@]} positional args)" >&2
      ;;
    why-not)
      echo "nix-why-option why-not: expected <flake-target> <option-path> (got ${#positional[@]} positional args)" >&2
      ;;
    search)
      echo "nix-why-option search: expected <flake-target> <pattern> (got ${#positional[@]} positional args)" >&2
      ;;
    *)
      echo "nix-why-option: expected <flake-target> <option-path> (got ${#positional[@]} positional args)" >&2
      ;;
  esac
  print_usage >&2
  exit 64
fi

# For search, positional[1] is a pattern; for the rest it is an option path.
option_path="${positional[1]}"
search_pattern="${positional[1]}"

case "$subcommand" in
  what-sets) library_fn="whatSets" ;;
  why-not) library_fn="whyNot" ;;
  search) library_fn="search" ;;
  *) library_fn="resolve" ;;
esac

# ---------------------------------------------------------------------------
# Build the nix eval invocation
# ---------------------------------------------------------------------------
# Each subcommand maps to a driver expression file in
# $NIX_WHY_CLI_EXPR_DIR:
#   - default / what-sets / why-not / search  -> resolve.nix
#   - eval                                    -> eval.nix
# All arguments are passed via --argstr (no shell-into-Nix interpolation),
# which eliminates an entire class of heredoc escape bugs.

if [[ "$subcommand" == "eval" ]]; then
  user_expr="${positional[0]}"

  # Write the user's Nix expression to a temp file and pass the path
  # to eval.nix - which imports it. This avoids interpolating
  # arbitrary user-supplied Nix into a shell heredoc.
  user_expr_file="$(mktemp --suffix=.nix)"
  trap 'rm -f "${user_expr_file}"' EXIT
  printf '%s\n' "$user_expr" > "${user_expr_file}"

  nix_eval_args=(
    --eval --strict --json --impure
    --argstr libPath "${NIX_WHY_LIB}"
    --argstr userExprFile "${user_expr_file}"
    --argstr optionPath "${option_path}"
    --argstr searchPattern "${search_pattern}"
    --argstr searchLimit "${search_limit}"
    --argstr adapterName "${adapter_name}"
    --argstr mode "${library_fn}"
    "${NIX_WHY_CLI_EXPR_DIR}/eval.nix"
  )

else
  split_flake_target "${positional[0]}"

  nix_eval_args=(
    --eval --strict --json --impure
    --argstr libPath "${NIX_WHY_LIB}"
    --argstr flakeRef "${flake_ref}"
    --argstr attr "${attr_expr}"
    --argstr optionPath "${option_path}"
    --argstr searchPattern "${search_pattern}"
    --argstr searchLimit "${search_limit}"
    --argstr adapterName "${adapter_name}"
    --argstr mode "${library_fn}"
    "${NIX_WHY_CLI_EXPR_DIR}/resolve.nix"
  )
fi
if ((show_trace)); then
  nix_eval_args+=(--show-trace)
fi

# Capture stdout and stderr separately so we can distinguish evaluation
# failures (exit 4) from option-not-found (exit 2 / 3) reported via the
# AST `kind` field.
ast_json=""
nix_stderr=""
nix_rc=0
{
  ast_json="$(nix-instantiate "${nix_eval_args[@]}" 2> /tmp/nix-why-option.stderr.$$)" || nix_rc=$?
  nix_stderr="$(cat /tmp/nix-why-option.stderr.$$)"
  rm -f /tmp/nix-why-option.stderr.$$
}

if ((nix_rc != 0)); then
  # Map well-known internal throws to specific exit codes. Anything else
  # is treated as a generic evaluation error (exit 4).
  case "$nix_stderr" in
    *"nix-why: '"*"' did not match any of "* | \
      *"nix-why: '"*"' is ambiguous"* | \
      *"nix-why: attribute path '"*"' not found"* | \
      *"nix-why: no attribute path given after"* | \
      *"nix-why: could not detect adapter"* | \
      *"nix-why: unknown adapter"*)
      echo "$nix_stderr" >&2
      exit 3
      ;;
    *)
      echo "$nix_stderr" >&2
      exit 4
      ;;
  esac
fi

# ---------------------------------------------------------------------------
# Inspect AST `kind` field for the early-exit cases
# ---------------------------------------------------------------------------
# resolve, whatSets, and whyNot all expose a `kind` field for the
# not-found / not-an-option early exits. search returns a different
# shape with no kind.
if [[ "$subcommand" != "search" ]]; then
  kind="$(printf '%s' "$ast_json" | jq -r '.kind')"
  case "$kind" in
    "option")
      # Defined or not, full output below. Exit code 1 if not defined.
      ;;
    "not-found")
      echo "nix-why-option: option '${option_path}' does not exist" >&2
      exit 2
      ;;
    "not-an-option")
      echo "nix-why-option: '${option_path}' exists in the options tree but is not a leaf option" >&2
      exit 2
      ;;
    *)
      echo "nix-why-option: unexpected AST kind '${kind}'" >&2
      exit 4
      ;;
  esac
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
# Pretty-print a definition's priorityKind: prefers the AST-provided
# label (from module-walk), falls back to deriving from the numeric
# priority when module-walk was unavailable.
kind_label() {
  local from_ast="$1"
  local prio="$2"
  if [[ -n "$from_ast" && "$from_ast" != "null" ]]; then
    printf '%s' "$from_ast"
  else
    printf '%s' "$(priority_label "$prio")"
  fi
}

priority_label() {
  case "$1" in
    10) echo "mkVMOverride" ;;
    50) echo "mkForce" ;;
    60) echo "mkImageMediaOverride" ;;
    100) echo "default" ;;
    1000) echo "mkDefault" ;;
    1500) echo "mkOptionDefault" ;;
    null) echo "unknown" ;;
    *) echo "mkOverride $1" ;;
  esac
}

# Render a JSON value for human consumption. Strings get their quotes
# stripped, other JSON types are emitted as-is. Truncates past max_value
# with a trailing ellipsis.
render_value() {
  local raw="$1"
  local maxv="$2"
  local plain
  if [[ "$raw" =~ ^\".*\"$ ]]; then
    plain="$(printf '%s' "$raw" | jq -r '.')"
  else
    plain="$raw"
  fi
  local len=${#plain}
  if ((len > maxv)); then
    printf '%s...' "${plain:0:$maxv}"
  else
    printf '%s' "$plain"
  fi
}

# ANSI color helpers. Bind to empty strings when colors are disabled so
# the call sites stay clean.
nix_why_init_colors

# ---------------------------------------------------------------------------
# Tree renderer
# ---------------------------------------------------------------------------
render_conflict() {
  local conflict="$1"
  local msg involved_count
  msg=$(jq -r '.message' <<< "$conflict")
  involved_count=$(jq -r '.involvedDefinitions | length' <<< "$conflict")

  printf '\n  %b⚠ CONFLICT%b: %s\n' "$C_RED" "$C_RESET" "$msg"
  if ((involved_count > 0)); then
    printf '  Involved definitions:\n'
    while IFS= read -r def; do
      local file line priority priorityKind value pos kind
      file=$(jq -r '.file // "<unknown>"' <<< "$def")
      line=$(jq -r '.line // empty' <<< "$def")
      priority=$(jq -r '.priority // "null"' <<< "$def")
      priorityKind=$(jq -r '.priorityKind // empty' <<< "$def")
      value=$(jq -c '.value' <<< "$def")
      pos="$(strip_store_prefix "$file")"
      [[ -n "$line" ]] && pos="${pos}:${line}"
      kind="$(kind_label "$priorityKind" "$priority")"
      printf '    - %s [%s] → %s\n' "$pos" "$kind" "$(render_value "$value" "$max_value")"
    done < <(jq -c '.involvedDefinitions[]' <<< "$conflict")
  fi
}

render_tree() {
  local ast="$1"

  local path type isDefined winningPriority def_count valueError conflict_count
  path=$(jq -r '.path' <<< "$ast")
  type=$(jq -r '.type // "unknown"' <<< "$ast")
  isDefined=$(jq -r '.isDefined' <<< "$ast")
  winningPriority=$(jq -r '.winningPriority // empty' <<< "$ast")
  def_count=$(jq -r '.definitions | length' <<< "$ast")
  valueError=$(jq -r '.valueError // empty' <<< "$ast")
  conflict_count=$(jq -r '.conflicts | length' <<< "$ast")

  # Header
  printf '%b%s%b : %b%s%b\n' "$C_BOLD" "$path" "$C_RESET" "$C_CYAN" "$type" "$C_RESET"

  # Value line: respects valueError (conflict case) and isDefined.
  if [[ -n "$valueError" ]]; then
    printf '  value     %b<unresolved - merge conflict>%b\n' "$C_RED" "$C_RESET"
  elif [[ "$isDefined" == "true" ]]; then
    local val_raw
    val_raw=$(jq -c '.value' <<< "$ast")
    printf '  value     %s\n' "$(render_value "$val_raw" "$max_value")"
  else
    printf '  value     %b<not defined>%b\n' "$C_DIM" "$C_RESET"
  fi

  # Declarations
  while IFS= read -r decl; do
    local f l
    f=$(strip_store_prefix "$(jq -r '.file' <<< "$decl")")
    l=$(jq -r '.line // empty' <<< "$decl")
    if [[ -n "$l" ]]; then
      printf '  declared  %s:%s\n' "$f" "$l"
    else
      printf '  declared  %s\n' "$f"
    fi
  done < <(jq -c '.declarations[]' <<< "$ast")

  # Conflicts block (v0.2): rendered before the definitions list.
  if ((conflict_count > 0)); then
    while IFS= read -r conflict; do
      render_conflict "$conflict"
    done < <(jq -c '.conflicts[]' <<< "$ast")
  fi

  echo

  # Definitions header
  if [[ -n "$winningPriority" ]]; then
    local winning_label
    winning_label="$(priority_label "$winningPriority")"
    printf '  %d definitions, winning priority %s (%s):\n\n' "$def_count" "$winningPriority" "$winning_label"
  else
    printf '  %d definitions:\n\n' "$def_count"
  fi

  # Definitions
  while IFS= read -r def; do
    render_def "$def"
    echo
  done < <(jq -c '.definitions[]' <<< "$ast")
}

render_def() {
  local def="$1"

  local file line priority priorityKind value wins guard_eval guard_src
  file=$(jq -r '.file // "<unknown>"' <<< "$def")
  line=$(jq -r '.line // empty' <<< "$def")
  priority=$(jq -r '.priority // "null"' <<< "$def")
  priorityKind=$(jq -r '.priorityKind // empty' <<< "$def")
  value=$(jq -c '.value' <<< "$def")
  wins=$(jq -r '.wins' <<< "$def")
  guard_eval=$(jq -r '.guardedBy.evaluatedTo // empty' <<< "$def")
  guard_src=$(jq -r '.guardedBy.source // empty' <<< "$def")

  local marker_glyph="  "
  if [[ "$wins" == "true" ]]; then
    marker_glyph="${C_GREEN}✓${C_RESET}"
  fi

  local pos
  pos="$(strip_store_prefix "$file")"
  [[ -n "$line" ]] && pos="${pos}:${line}"
  printf '%b %s\n' "$marker_glyph" "$pos"

  # Priority line with mkIf annotation when guarded.
  local kind_disp
  kind_disp="$(kind_label "$priorityKind" "$priority")"
  local kind_full="$kind_disp"
  [[ -n "$guard_eval" ]] && kind_full="${kind_disp}, via mkIf"

  local annot=""
  if [[ "$wins" == "false" && -z "$guard_eval" ]]; then
    annot="${C_DIM}        ← overridden by higher-priority definitions${C_RESET}"
  fi

  if [[ "$priority" != "null" ]]; then
    printf '        priority %s (%s)%s\n' "$priority" "$kind_full" "$annot"
  else
    printf '        priority unknown (%s)\n' "$kind_full"
  fi

  # The contributed value.
  printf '        → %s\n' "$(render_value "$value" "$max_value")"

  # mkIf condition line, when guarded.
  if [[ -n "$guard_eval" ]]; then
    local src_disp="${guard_src:-<source unavailable>}"
    local filt_annot=""
    if [[ "$guard_eval" == "false" ]]; then
      filt_annot="   ${C_DIM}← filtered out${C_RESET}"
    fi
    printf '        condition: %s  → %s%s\n' "$src_disp" "$guard_eval" "$filt_annot"
  fi
}

# ---------------------------------------------------------------------------
# Render
# ---------------------------------------------------------------------------
render_brief() {
  local ast="$1"
  local path value isDefined winningPriority def_count file_count
  path=$(jq -r '.path' <<< "$ast")
  value=$(jq -c '.value' <<< "$ast")
  isDefined=$(jq -r '.isDefined' <<< "$ast")
  winningPriority=$(jq -r '.winningPriority // "null"' <<< "$ast")
  def_count=$(jq -r '.definitions | length' <<< "$ast")
  file_count=$(jq -r '[.definitions[].file] | unique | length' <<< "$ast")

  if [[ "$isDefined" == "true" ]]; then
    printf '%s = %s  (prio %s, %d defs across %d files)\n' \
      "$path" \
      "$(render_value "$value" "$max_value")" \
      "$winningPriority" \
      "$def_count" \
      "$file_count"
  else
    printf '%s = <not defined>\n' "$path"
  fi
}

render_what_sets() {
  local ast="$1"
  local path type isDefined setter_count
  path=$(jq -r '.path' <<< "$ast")
  type=$(jq -r '.type // "unknown"' <<< "$ast")
  isDefined=$(jq -r '.isDefined' <<< "$ast")
  setter_count=$(jq -r '.setters | length' <<< "$ast")

  printf '%b%s%b : %b%s%b\n' "$C_BOLD" "$path" "$C_RESET" "$C_CYAN" "$type" "$C_RESET"
  printf '  isDefined %s\n' "$isDefined"

  while IFS= read -r decl; do
    local f l
    f=$(jq -r '.file' <<< "$decl")
    l=$(jq -r '.line // empty' <<< "$decl")
    if [[ -n "$l" ]]; then
      printf '  declared  %s:%s\n' "$f" "$l"
    else
      printf '  declared  %s\n' "$f"
    fi
  done < <(jq -c '.declarations[]' <<< "$ast")

  echo

  printf '  %d module%s set this option:\n\n' "$setter_count" "$(plural_s "$setter_count")"

  while IFS= read -r setter; do
    local file line priority priorityKind guard_eval pos kind
    file=$(jq -r '.file // "<unknown>"' <<< "$setter")
    line=$(jq -r '.line // empty' <<< "$setter")
    priority=$(jq -r '.priority // "null"' <<< "$setter")
    priorityKind=$(jq -r '.priorityKind // empty' <<< "$setter")
    guard_eval=$(jq -r '.guardedBy.evaluatedTo // empty' <<< "$setter")
    pos="$(strip_store_prefix "$file")"
    [[ -n "$line" ]] && pos="${pos}:${line}"
    kind="$(kind_label "$priorityKind" "$priority")"

    local annotation=""
    if [[ -n "$guard_eval" ]]; then
      if [[ "$guard_eval" == "false" ]]; then
        annotation="  ${C_DIM}(filtered out by mkIf)${C_RESET}"
      else
        annotation="  ${C_DIM}(via mkIf, condition held)${C_RESET}"
      fi
    fi

    printf '    - %s [%s]%s\n' "$pos" "$kind" "$annotation"
  done < <(jq -c '.setters[]' <<< "$ast")
}

render_what_sets_brief() {
  local ast="$1"
  local path setter_count
  path=$(jq -r '.path' <<< "$ast")
  setter_count=$(jq -r '.setters | length' <<< "$ast")
  printf '%s: %d setter%s\n' "$path" "$setter_count" "$(plural_s "$setter_count")"
}

render_search() {
  local ast="$1"
  local pattern total truncated
  pattern=$(jq -r '.pattern' <<< "$ast")
  total=$(jq -r '.totalMatches' <<< "$ast")
  truncated=$(jq -r '.truncated' <<< "$ast")

  printf 'pattern: %b%s%b\n' "$C_BOLD" "$pattern" "$C_RESET"
  printf 'matches: %d%s\n\n' "$total" "$([[ "$truncated" == "true" ]] && echo " (truncated; pass --limit 0 for all)")"

  while IFS= read -r match; do
    local path type isDefined
    path=$(jq -r '.path' <<< "$match")
    type=$(jq -r '.type // "?"' <<< "$match")
    isDefined=$(jq -r '.isDefined' <<< "$match")
    local marker="  "
    [[ "$isDefined" == "true" ]] && marker="${C_GREEN}*${C_RESET}"
    printf '%b %s %b[%s]%b\n' "$marker" "$path" "$C_DIM" "$type" "$C_RESET"
  done < <(jq -c '.matches[]' <<< "$ast")
}

render_search_brief() {
  local ast="$1"
  jq -r '.matches[].path' <<< "$ast"
}

render_def_line() {
  local def="$1"
  local file line priority priorityKind value pos kind
  file=$(jq -r '.file // "<unknown>"' <<< "$def")
  line=$(jq -r '.line // empty' <<< "$def")
  priority=$(jq -r '.priority // "null"' <<< "$def")
  priorityKind=$(jq -r '.priorityKind // empty' <<< "$def")
  value=$(jq -c '.value' <<< "$def")
  pos="$(strip_store_prefix "$file")"
  [[ -n "$line" ]] && pos="${pos}:${line}"
  kind="$(kind_label "$priorityKind" "$priority")"
  printf '    - %s [%s] → %s\n' "$pos" "$kind" "$(render_value "$value" "$max_value")"
}

render_why_not() {
  local ast="$1"
  local path type value isExplicitlySet explicit_count default_count filtered_count hint
  path=$(jq -r '.path' <<< "$ast")
  type=$(jq -r '.type // "unknown"' <<< "$ast")
  value=$(jq -c '.value' <<< "$ast")
  isExplicitlySet=$(jq -r '.isExplicitlySet' <<< "$ast")
  explicit_count=$(jq -r '.explicitDefinitions | length' <<< "$ast")
  default_count=$(jq -r '.defaultDefinitions | length' <<< "$ast")
  filtered_count=$(jq -r '.filteredOutDefinitions | length' <<< "$ast")
  hint=$(jq -r '.hint // empty' <<< "$ast")

  printf '%b%s%b : %b%s%b\n' "$C_BOLD" "$path" "$C_RESET" "$C_CYAN" "$type" "$C_RESET"
  printf '  value     %s\n' "$(render_value "$value" "$max_value")"

  while IFS= read -r decl; do
    local f l
    f=$(jq -r '.file' <<< "$decl")
    l=$(jq -r '.line // empty' <<< "$decl")
    if [[ -n "$l" ]]; then
      printf '  declared  %s:%s\n' "$f" "$l"
    else
      printf '  declared  %s\n' "$f"
    fi
  done < <(jq -c '.declarations[]' <<< "$ast")

  echo
  if [[ "$isExplicitlySet" == "true" ]]; then
    printf '  %bThis option IS explicitly set%b by %d user definition%s.\n' \
      "$C_GREEN" "$C_RESET" "$explicit_count" "$(plural_s "$explicit_count")"
    printf '  Run `nix-why-option <target> %s` (without why-not) for the full resolution view.\n' "$path"
    echo
    printf '  Explicit definitions:\n'
    while IFS= read -r d; do render_def_line "$d"; done < <(jq -c '.explicitDefinitions[]' <<< "$ast")
  else
    printf '  %bThis option is NOT explicitly set%b - only the type default contributes.\n' \
      "$C_YELLOW" "$C_RESET"
    if ((default_count > 0)); then
      echo
      printf '  Type default (priority 1500):\n'
      while IFS= read -r d; do render_def_line "$d"; done < <(jq -c '.defaultDefinitions[]' <<< "$ast")
    fi
    if ((filtered_count > 0)); then
      echo
      printf '  %b%d definition%s would set this option, but their mkIf guards evaluated false:%b\n' \
        "$C_DIM" "$filtered_count" "$(plural_s "$filtered_count")" "$C_RESET"
      while IFS= read -r d; do
        local file line guard_src
        file=$(jq -r '.file // "<unknown>"' <<< "$d")
        line=$(jq -r '.line // empty' <<< "$d")
        guard_src=$(jq -r '.guardedBy.source // "<unknown condition>"' <<< "$d")
        local pos="$file"
        [[ -n "$line" ]] && pos="${file}:${line}"
        printf '    - %s\n' "$pos"
        printf '        would set when %b%s%b\n' "$C_CYAN" "$guard_src" "$C_RESET"
      done < <(jq -c '.filteredOutDefinitions[]' <<< "$ast")
    fi
    if [[ -n "$hint" ]]; then
      echo
      printf '  %bHint:%b %s\n' "$C_BOLD" "$C_RESET" "$hint"
    fi
  fi
}

render_why_not_brief() {
  local ast="$1"
  local path isExplicitlySet filtered_count
  path=$(jq -r '.path' <<< "$ast")
  isExplicitlySet=$(jq -r '.isExplicitlySet' <<< "$ast")
  filtered_count=$(jq -r '.filteredOutDefinitions | length' <<< "$ast")
  if [[ "$isExplicitlySet" == "true" ]]; then
    printf '%s: explicitly set\n' "$path"
  else
    printf '%s: NOT explicitly set (%d filtered-out def%s)\n' \
      "$path" "$filtered_count" "$(plural_s "$filtered_count")"
  fi
}

case "$format" in
  json)
    printf '%s\n' "$ast_json"
    ;;
  tree)
    case "$subcommand" in
      what-sets) render_what_sets "$ast_json" ;;
      search) render_search "$ast_json" ;;
      why-not) render_why_not "$ast_json" ;;
      *) render_tree "$ast_json" ;;
    esac
    ;;
  brief)
    case "$subcommand" in
      what-sets) render_what_sets_brief "$ast_json" ;;
      search) render_search_brief "$ast_json" ;;
      why-not) render_why_not_brief "$ast_json" ;;
      *) render_brief "$ast_json" ;;
    esac
    ;;
esac

# moduleWalkAvailable=false triggers an informational notice, but only
# when --verbose is set. By default this is silent: hitting this state
# on a stock NixOS config is the common case, not an exceptional one.
if ((verbose)) \
  && [[ "$subcommand" != "search" ]] \
  && [[ "$(printf '%s' "$ast_json" | jq -r '.moduleWalkAvailable')" == "false" ]]; then
  echo "note: nix-why-option: module-walk introspection unavailable" >&2
  echo "      (per-definition priorities and line numbers will be missing)" >&2
  echo "      opt-in: set _module.args.modules = <your module list> in your config" >&2
fi

# Exit code: search is 0 if any matches, otherwise treat as not-found.
if [[ "$subcommand" == "search" ]]; then
  total="$(printf '%s' "$ast_json" | jq -r '.totalMatches')"
  if [[ "$total" == "0" ]]; then
    exit 2
  fi
  exit 0
fi

# why-not: exit 0 when the option is explicitly set or has filtered-out
# candidates we can report on; exit 1 when there is literally nothing
# but the type default (informational, mirrors the "declared but
# undefined" exit on resolve).
if [[ "$subcommand" == "why-not" ]]; then
  is_explicit="$(printf '%s' "$ast_json" | jq -r '.isExplicitlySet')"
  filtered="$(printf '%s' "$ast_json" | jq -r '.filteredOutDefinitions | length')"
  if [[ "$is_explicit" == "false" ]] && [[ "$filtered" == "0" ]]; then
    exit 1
  fi
  exit 0
fi

is_defined="$(printf '%s' "$ast_json" | jq -r '.isDefined')"
if [[ "$is_defined" == "false" ]]; then
  exit 1
fi
exit 0
